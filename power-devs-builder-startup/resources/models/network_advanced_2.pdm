                                                                                                                        ipSender = Str; %ipSender ; IP address of the sender (the one of the sender).\nThe string is used directly as IP address. It can not be a variable name as it is not looked in the parameters.
                                                                                                                        ipReceiver = Str; %ipReceiver ; IP address of the receiver (my IP).\nThe string is used directly as IP address. It can not be a variable name as it is not looked in the parameters.
                                                                                                                        portSender = Str; 4 ; TCP port of the sender
                                                                                                                        portReceiver = Str; 4 ; TCP port of the receiver (my port)
                                                                                                                        }
                                                                                                                    }
