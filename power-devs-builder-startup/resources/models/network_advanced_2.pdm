                                        ValueChanges2 = Str;  ; 2nd derivative
                                        ValueChanges3 = Str;  ; 3rd derivative
                                        }
                                    }
                                Atomic
                                    {
                                    Name = TCP_SND
                                    Ports = 2 ; 2
                                    Path = network/packettcpsnd.h
                                    Description = Receives packets from the upper layer (application) and forwards them using a congestion control mechanism of TCP protocol ([SW94] y [SW95])
                                    Graphic
                                        {
                                        Position = 4485 ; 75
                                        Dimension = 780 ; 750
                                        Direction = Right
                                        Color = 15
                                        Icon = %datanetworks%tocketbucket.png
                                        }
                                    Parameters
                                        {
                                        MSS = Str; %TCP.MSS ; 
                                        ipSender = Str; %ipSender ; My IP address (the one of the sender).\nThe string is used directly as IP address. It can not be a variable name as it is not looked in the parameters.
                                        ipReceiver = Str; %ipReceiver ; IP address of the receiver.\nThe string is used directly as IP address. It can not be a variable name as it is not looked in the parameters.
                                        portSender = Str; %portSender ; My Port. TCP port of the sender
                                        portReceiver = Str; %portReceiver ; TCP port of the receiver
                                        WND_CWND_MAX = Str; %TCP.CWND_max ; MAX Congestion Window (in packets) inf==NONE, Typical: 64
                                        WND_SSTHRESH = Str; %TCP.CWND_ssthresh ; Experimental Slow Start, 0==OFF
                                        RTT_alfa = Str; 0.125 ; Typical value 0.125. RTT_alfa==0 => No moving average for RTT, only instantaneous measurements
                                        T_RTT = Str; %TCP.RTT_initial ; Initial Calculated Round Trip Time
                                        DUP_ACK_LIMIT = Str; 3 ; Typical value 3
                                        T_FORCED_RTO = Str; -1 ; T_FORCED_RTO>=0 => Forces RTO instead of calculating it
                                        INTERPACKET_SND_TIME = Str; 0 ; It should look like "instantaneous" compared to RTT, maybe RTT/1000 is a good rule of thumb
                                        INTER_REQ_TIME = Str; 1e-7 ; Should look like "instantaneous" compared to RTT, maybe RTT/1000 is a good rule of thumb
                                        }
                                    }
