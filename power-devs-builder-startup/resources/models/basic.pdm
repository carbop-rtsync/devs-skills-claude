    System
        {
        Atomic
            {
            Name = DataHandler
            Ports = 0 ; 1
            Path = queueing/JobGenerator.h
            Description = Generates jobs using a distribution for the rate and jobSize.
            Graphic
                {
                Position = -13005 ; -1755
